---
import Base from "../layouts/Base.astro";
import GameCard from "./GameCard.astro";
import { picks, relatedPicks, rarityStamps, lineageIds, lineageName, JST_OFFSET_MIN } from "../data/picks";
import { SITE } from "../data/site";
import { ogUrlPath } from "../../scripts/og-card.config.mjs";
import { pickJsonLd, representativeName } from "../lib/jsonld";
import { useTranslations, tn, defaultLang } from "../i18n/ui";
import type { Lang } from "../i18n/ui";

interface Props {
  slug: string;
}
const { slug } = Astro.props;
const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const pick = picks[slug];
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const c = pick[lang];
const t = useTranslations(lang);
const jsonld = pickJsonLd(slug, lang, pageUrl, t("nav.home"));
const isJa = lang === "ja";
const g0 = pick.games[0];
const g1 = pick.games[1];
const pubLine = (isJa ? "公開 " : "Published ") + pick.published;
const goodLabel = isJa ? "刺さる" : "For you";
const badLabel = isJa ? "合わない" : "Not for you";
const backHref = isJa ? "/ja/" : "/";
const g0tag = isJa ? g0.tag_ja : g0.tag_en;
const g0desc = isJa ? g0.desc_ja : g0.desc_en;
const g1tag = isJa ? g1.tag_ja : g1.tag_en;
const g1desc = isJa ? g1.desc_ja : g1.desc_en;
const g0name = isJa ? (g0.name_ja || g0.name_en) : (g0.name_en || g0.name_ja);
const g1name = isJa ? (g1.name_ja || g1.name_en) : (g1.name_en || g1.name_ja);
const repName = representativeName(pick, lang);
// 【未来の投稿を予約】このページの公開予定日(JST)。無ければ即公開(後方互換)。
// SSR は本文を必ず出力(cron 無し方式・AEO)。client JS が now(JST) < publishAt のとき
// 本文を隠し coming-soon に差し替える(脳と体の分離・判定 TZ は picks.ts が真実源)。
const publishAt = pick.publishAt ?? "";
const soonOn = publishAt ? tn(lang, "soon.on", publishAt) : "";

// 【案C 希少性スタンプ】data 由来の事実キーを i18n ラベルへ変換(捏造しない・煽らない)。
// lead が hidden gem の find ページでだけ立つ。established/hub では空(沈黙)。
function rarityLabel(kind: string, value: number | boolean): string {
  if (kind === "positivePct") return tn(lang, "rarity.positivePct", value as number);
  if (kind === "reviews") return tn(lang, "rarity.reviews", value as number);
  return t(("rarity." + kind) as any);
}
const rarity = rarityStamps(slug).map(function (s) { return rarityLabel(s.kind, s.value); });

// 【案B 系譜を辿れる地図】同原点(sibling)を優先し、別の味(branch)を1本足してループを閉じない。
const related = relatedPicks(slug).map(function (r) {
  return {
    href: (isJa ? "/ja/picks/" : "/picks/") + r.slug + "/",
    name: representativeName(picks[r.slug], lang),
    relation: r.relation,
    // 未来の投稿を予約: 相互リンク先が未公開なら client 側で隠す(一覧と整合)。
    publishAt: picks[r.slug].publishAt ?? "",
  };
});
const siblings = related.filter(function (r) { return r.relation === "sibling"; });
const branches = related.filter(function (r) { return r.relation === "branch"; });

// 【案1 縦血統ライン】原点(root)を多親対応で解決。lineageIds で配列化し各 root 名を逆引き(SSOT)。
// null(同定不能)は捏造せず出さない。多親(Bit Oz hub)は root が複数行で並ぶ(二親の視覚化)。
const roots = lineageIds(pick.meta)
  .map(function (id) { return lineageName(id, lang); })
  .filter(function (n): n is string { return n !== null; });
const multiRoot = roots.length > 1;
// この pick 固有の OG カード絶対 URL(ビルド前に public/og/<slug>(.ja).png を生成済み)。
// SITE.url 由来 = SSOT。命名規約は ogUrlPath に一元化(gen-og-cards と同一規約・ズレ防止)。
const ogImage = SITE.url + ogUrlPath(slug, isJa);
---
<Base title={c.title} description={c.description} jsonld={jsonld} ogImage={ogImage}>
  <main class="wrap" style="padding-top:48px;padding-bottom:0" data-pickgate data-publish-at={publishAt}>

    <!-- 公開予定面: now(JST) < publishAt のときだけ client JS が表示する。SSR では常に hidden
         (= 期日後/JS-off は本文をそのまま読める)。本文は下に必ず deploy 済み(cron 無し方式)。 -->
    {publishAt && (
      <section class="soon" data-soon hidden>
        <span class="kicker"><span class="dot"></span> {t("soon.kicker")}</span>
        <h1>{t("soon.heading")}</h1>
        <p class="lede">{t("soon.body")}</p>
        <p class="soon-on" data-soon-on aria-live="polite">{soonOn}</p>
        <p><a href={backHref}>{t("soon.back")}</a></p>
      </section>
    )}

    <!-- 本文: SSR で常に出力(AEO/JS-off)。now(JST) < publishAt のとき client JS が hidden にする。 -->
    <div data-pickbody>

    <nav aria-label="breadcrumb" style="font-size:13px;color:var(--muted);margin-bottom:6px"><a href={backHref}>{t("nav.home")}</a> / {repName}</nav>

    <span class="kicker"><span class="dot"></span> {t("kicker")}</span>
    <h1>{c.h1a}<span class="flip">{c.h1flip}</span>{c.h1b}</h1>
    <p class="lede">{c.lede}</p>
    <p style="color:var(--muted);font-size:13px">{pubLine}</p>

    <h2><span class="num">01</span>{c.s1}</h2>
    <ul class="feel">
      <li>{c.feeling[0]}</li>
      <li>{c.feeling[1]}</li>
      <li>{c.feeling[2]}</li>
    </ul>

    <h2><span class="num">02</span>{c.s2}</h2>
    <div class="cols">
      <div class="col good">
        <h3>{goodLabel}</h3>
        <ul>
          <li>{c.good[0]}</li>
          <li>{c.good[1]}</li>
          <li>{c.good[2]}</li>
        </ul>
      </div>
      <div class="col bad">
        <h3>{badLabel}</h3>
        <ul>
          <li>{c.bad[0]}</li>
          <li>{c.bad[1]}</li>
        </ul>
      </div>
    </div>

    <h2><span class="num">03</span>{c.s3}</h2>
    {rarity.length > 0 && (
      <!-- 案C 希少性スタンプ: 静かな対比。数字は picks.ts のデータ由来(捏造なし・煽り語なし) -->
      <p class="rarity" aria-label={t("rarity.label")}>
        {rarity.map((r, i) => (
          <span class="rstamp">{i > 0 ? <span class="rsep" aria-hidden="true">·</span> : null}{r}</span>
        ))}
        <span class="ryet"> — {t("rarity.yet")}</span>
      </p>
    )}
    <GameCard name={g0name} tag={g0tag} desc={g0desc} steam={g0.steam} />
    <GameCard name={g1name} tag={g1tag} desc={g1desc} steam={g1.steam} />

    <h2><span class="num">04</span>{t("cta.passHeading")}</h2>
    <p class="lede">{t("cta.passBody")}</p>
    <!-- 案D 合格 push juice: 押下で原石が一段輝く(hidden -> surfaced)。Steam 遷移は妨げない
         (target=_blank で別タブ遷移は必ず起きる)。装飾は presentation 層が emitEvent 受信で発火。 -->
    <div class="passzone" data-passzone>
      <span class="gemglint" data-gemglint aria-hidden="true"></span>
      <a class="btn" data-passcta href={g0.steam} target="_blank" rel="noopener">{t("store.see")}</a>
      <p class="passecho" data-passecho aria-live="polite" hidden>{t("juice.pressed")}</p>
    </div>

    <h2><span class="num">05</span>{t("lineage.tree.heading")}</h2>
    <!-- 案1 縦血統ライン: 原点(root) -> 現在地(self) -> 兄弟(sibling) -> 別の味(branch)。
         nested ul/li + CSS 擬似要素罫線(SVG なし・role=tree なし・aria-label のみ)。
         JS-off でも入れ子リストが全文 SSR されて読める。未公開先は client が data-related で隠す。 -->
    <ul class="lineage-tree" aria-label={t("lineage.tree.aria")}>
      <!-- 原点(root): 多親なら複数行で横並び(二親の視覚化)。null(同定不能)は出さない -->
      {roots.map((rootName) => (
        <li class="lin-node lin-root" data-lin-role="root">
          <span class="lin-name">{rootName}</span>
          <span class="lin-role-flag root">{t("lineage.role.root")}</span>
        </li>
      ))}
      {multiRoot && (
        <li class="lin-cross" data-lin-role="cross"><span class="lin-cross-note">{t("lineage.crossroot")}</span></li>
      )}
      <!-- 現在地(self): このページ自身。data-self で強調。配下に兄弟と別の味をぶら下げる -->
      <li class="lin-node lin-self" data-lin-role="self">
        <span class="lin-name">{repName}</span>
        <span class="lin-role-flag here">{t("lineage.role.here")}</span>
        {(siblings.length > 0 || branches.length > 0) && (
          <ul class="lineage-children">
            {siblings.map((r) => (
              <li class="lin-node lin-sibling" data-related data-publish-at={r.publishAt} data-lin-role="sibling">
                <a href={r.href}>{r.name}</a>
                <span class="lin-role-flag sib">{t("lineage.role.sibling")}</span>
              </li>
            ))}
            {branches.map((r) => (
              <li class="lin-node lin-branch" data-related data-publish-at={r.publishAt} data-lin-role="branch">
                <a href={r.href}>{r.name}</a>
                <span class="lin-role-flag br">{t("lineage.role.branch")}</span>
              </li>
            ))}
          </ul>
        )}
      </li>
    </ul>

    <footer><a href={backHref}>{t("home.back")}</a></footer>

    </div>
  </main>

  <!-- 案D 体(presentation 層): emitEvent 経由でだけ装飾を発火。ロジックは見た目を知らない。
       押下イベント "uncut:pass" を dispatch -> リスナが gemglint/surfaced を立てる。
       偽カウンター無し(個人 localStorage の記録のみ)。Steam 遷移(別タブ)は奪わない。 -->
  <script
    is:inline
    define:vars={{ passSlug: slug, storeKey: "uncut.passed." + slug }}
  >
    (function () {
      var zone = document.querySelector("[data-passzone]");
      if (!zone) return;
      var cta = zone.querySelector("[data-passcta]");
      var echo = zone.querySelector("[data-passecho]");
      if (!cta) return;

      // emitEvent: ロジックは「押された」事実だけを発行。装飾は受信側が決める(脳と体の分離)。
      function emitPass() {
        zone.dispatchEvent(
          new CustomEvent("uncut:pass", { bubbles: true, detail: { slug: passSlug } })
        );
      }

      // 受信側(体): hidden -> surfaced。data-surfaced を立てるだけ、見た目は CSS が持つ。
      zone.addEventListener("uncut:pass", function () {
        zone.setAttribute("data-surfaced", "1");
        if (echo) echo.hidden = false;
        // 個人の記録のみ(社会的カウンターは作らない)。次回訪問でも surfaced を保つ。
        try { localStorage.setItem(storeKey, "1"); } catch (e) {}
      });

      // 既に一度合格させていれば、最初から surfaced(個人記録の復元・偽数値ではない)。
      try { if (localStorage.getItem(storeKey) === "1") zone.setAttribute("data-surfaced", "1"); } catch (e) {}

      // 押下で発火。リンク本来の遷移(別タブ)は preventDefault しない = Steam を妨げない。
      cta.addEventListener("click", function () { emitPass(); });
    })();
  </script>

  <!-- 体(time-gate): 脳(picks.ts)と同じ式で now(JST) と publishAt を比較し、未公開なら本文を
       隠して coming-soon を見せる。判定の TZ(jstOffsetMin)は SSR 由来 = SSOT(JS にベタ書きしない)。
       期日が来たら再ビルド無しで次回訪問時に自動表示される(Cloudflare cron 無し方式)。 -->
  <script
    is:inline
    define:vars={{ jstOffsetMin: JST_OFFSET_MIN }}
  >
    (function () {
      var gate = document.querySelector("[data-pickgate]");
      if (!gate) return;
      var nowMs = Date.now(); // UTC epoch(ms)。端末 TZ に依存しない絶対時刻。

      // publishAt("YYYY-MM-DD" JST)を UTC epoch(ms)へ。脳 publishAtToUtcMs と同一式(SSOT)。
      // 無し/不正 = null(判定不能 = 呼び出し側が公開扱い・後方互換)。
      function publishAtUtcMs(s) {
        var m = /^(\d{4})-(\d{2})-(\d{2})$/.exec(s || "");
        if (!m) return null;
        return Date.UTC(parseInt(m[1], 10), parseInt(m[2], 10) - 1, parseInt(m[3], 10))
          - jstOffsetMin * 60 * 1000;
      }
      function isPublished(s) {
        var at = publishAtUtcMs(s);
        return at === null ? true : nowMs >= at;
      }

      // (1) このページ本文の gate: 未公開なら本文を隠し coming-soon を見せる。
      //     見た目は CSS が持つ(ここは可視性だけ切替)。期日後/JS-off は本文そのまま。
      if (!isPublished(gate.getAttribute("data-publish-at"))) {
        var body = gate.querySelector("[data-pickbody]");
        var soon = gate.querySelector("[data-soon]");
        if (body) body.hidden = true;
        if (soon) soon.hidden = false;
      }

      // (2) 相互リンク(related)の gate: 公開ページでも未公開先は隠す(一覧と整合)。
      var rels = gate.querySelectorAll("[data-related]");
      for (var i = 0; i < rels.length; i++) {
        if (!isPublished(rels[i].getAttribute("data-publish-at"))) rels[i].hidden = true;
      }
    })();
  </script>
</Base>
